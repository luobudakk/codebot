# Copy this file to .env and fill in your real values.
# Do not commit .env.

# API service
API_HOST=0.0.0.0
API_PORT=8000

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=advanced_rag_kb
QDRANT_VECTOR_SIZE=1024

# Neo4j
NEO4J_ENABLED=true
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=advanced-rag-dev-change-me
# Used by docker-compose for local Neo4j container auth
NEO4J_AUTH=neo4j/advanced-rag-dev-change-me

# Embedding / retrieval
EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_MODEL_PATH=
# HF_ENDPOINT=
CHUNK_TARGET_CHARS=900
CHUNK_OVERLAP_CHARS=120
CHUNK_MAX_CODE_CHARS=8000
RETRIEVAL_TOP_K=100
RETRIEVAL_SCORE_THRESHOLD=0.7
RETRIEVAL_RERANK_ENABLED=true
RETRIEVAL_RERANK_MODEL=BAAI/bge-reranker-base
# RETRIEVAL_RERANK_MODEL_PATH=
RETRIEVAL_RERANK_TOP_POOL=80

# LLM (OpenAI-compatible)
LLM_API_KEY=
# LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# Optional eval/judge model
# JUDGE_MODEL=
AGENT_CONTEXT_MAX_CHARS=12000
